<%# app/views/admin/reports/order_statuses.html.erb %>
<%= link_to "← Natrag", admin_reports_path,
            class: "inline-block px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-lg font-semibold transition mb-4" %>
<h1 class="text-2xl font-bold mb-2">Statusi narudžbi u periodu</h1>
<p class="text-sm text-gray-600 mb-6"><%= @from %> → <%= @to %></p>

<%= render "range_form", url: order_statuses_admin_reports_path %>

<div class="bg-white border rounded-lg p-4 mb-6">
  <h2 class="text-lg font-bold mb-3">Raspodjela statusa narudžbi</h2>
  <div id="statuses_chart" style="width: 100%; height: 360px;"></div>

  <script>
      google.charts.load("current", { packages: ["corechart"] });
      google.charts.setOnLoadCallback(drawStatusesChart);

      function drawStatusesChart() {
          const data = google.visualization.arrayToDataTable([
              ["Status", "Broj"],
              <% @rows.each do |status, count| %>
              ["<%= status %>", <%= count.to_i %>],
              <% end %>
          ]);

          const options = {
              legend: { position: "right" },
              pieHole: 0.35
          };

          const chart = new google.visualization.PieChart(document.getElementById("statuses_chart"));
          chart.draw(data, options);
      }
  </script>
</div>

<div class="bg-white border rounded-lg overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50 text-sm text-gray-600">
    <tr>
      <th class="text-left p-3">Status</th>
      <th class="text-right p-3">Broj</th>
    </tr>
    </thead>
    <tbody class="divide-y">
    <% @rows.each do |status, count| %>
      <tr>
        <td class="p-3 font-semibold"><%= status %></td>
        <td class="p-3 text-right"><%= count %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>