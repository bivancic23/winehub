<%# app/views/admin/reports/top_products.html.erb %>
<%= link_to "← Natrag", admin_reports_path,
            class: "inline-block px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-lg font-semibold transition mb-4" %>
<h1 class="text-2xl font-bold mb-2">Top proizvodi</h1>
<p class="text-sm text-gray-600 mb-6"><%= @from %> → <%= @to %></p>


<%= render "range_form", url: top_products_admin_reports_path %>
<div class="bg-white border rounded-lg p-4 mb-6">
  <h2 class="text-lg font-bold mb-3">Top 10 proizvoda po prihodu</h2>
  <div id="products_chart" style="width: 100%; height: 420px;"></div>

  <script>
      google.charts.load("current", { packages: ["corechart"] });
      google.charts.setOnLoadCallback(drawProductsChart);

      function drawProductsChart() {
          const data = google.visualization.arrayToDataTable([
              ["Proizvod", "Prihod"],
              <% @rows.limit(10).each do |r| %>
              ["<%= j r.name %>", <%= r.revenue_cents.to_i / 100.0 %>],
              <% end %>
          ]);

          const options = {
              legend: { position: "none" },
              vAxis: { title: "Prihod (€)" },
              hAxis: { title: "Proizvodi" }
          };

          const chart = new google.visualization.ColumnChart(document.getElementById("products_chart"));
          chart.draw(data, options);
      }
  </script>
</div>

<div class="bg-white border rounded-lg overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50 text-sm text-gray-600">
    <tr>
      <th class="text-left p-3">Proizvod</th>
      <th class="text-left p-3">SKU</th>
      <th class="text-right p-3">Količina</th>
      <th class="text-right p-3">Prihod</th>
    </tr>
    </thead>
    <tbody class="divide-y">
    <% @rows.each do |r| %>
      <tr>
        <td class="p-3 font-semibold"><%= r.name %></td>
        <td class="p-3 font-mono text-sm"><%= r.sku %></td>
        <td class="p-3 text-right"><%= r.qty.to_i %></td>
        <td class="p-3 text-right font-semibold"><%= number_to_currency(r.revenue_cents.to_i / 100.0, unit: "€") %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>