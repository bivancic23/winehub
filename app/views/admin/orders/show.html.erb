<% btn_primary = "px-4 py-2 rounded-lg text-sm font-semibold shadow-sm bg-blue-600 text-white hover:bg-blue-700 transition" %>
<% btn_gray    = "px-4 py-2 rounded-lg text-sm font-semibold shadow-sm bg-gray-200 text-gray-800 hover:bg-gray-300 transition" %>
<% btn_green   = "px-4 py-2 rounded-lg text-sm font-semibold shadow-sm bg-green-600 text-white hover:bg-green-700 transition" %>
<% btn_red     = "px-4 py-2 rounded-lg text-sm font-semibold shadow-sm bg-red-600 text-white hover:bg-red-700 transition" %>

<div class="max-w-6xl mx-auto">

  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-6">
    <div>
      <div class="text-sm text-gray-500 mb-1">
        <%= link_to "← Natrag na narudžbe", admin_orders_path(scope: params[:scope]), class: "hover:underline" %>
      </div>

      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-gray-900">Narudžba #<%= @order.id %></h1>

        <% status_label =
             case @order.status
             when "draft" then "Skica"
             when "submitted" then "Poslana"
             when "approved" then "Odobrena"
             when "preparing" then "U pripremi"
             when "shipped" then "Poslana kupcu"
             when "delivered" then "Dostavljena"
             when "rejected" then "Odbijena"
             when "cancelled" then "Otkazana"
             else @order.status
             end
        %>

        <span class="px-2 py-1 rounded text-xs font-semibold
          <%=
          case @order.status
          when "submitted" then "bg-yellow-100 text-yellow-800"
          when "approved"  then "bg-blue-100 text-blue-800"
          when "preparing" then "bg-indigo-100 text-indigo-800"
          when "shipped"   then "bg-purple-100 text-purple-800"
          when "delivered" then "bg-green-100 text-green-800"
          when "rejected", "cancelled" then "bg-red-100 text-red-800"
          else "bg-gray-100 text-gray-700"
          end
        %>">
          <%= status_label %>
        </span>

        <% if @order.submitted? %>
          <span class="px-2 py-1 rounded text-xs font-bold bg-yellow-200 text-yellow-800">NOVO</span>
        <% end %>

        <% if @order.overdue? %>
          <span class="px-2 py-1 rounded text-xs font-bold bg-red-600 text-white">KAŠNJENJE</span>
        <% end %>
      </div>

      <div class="mt-2 text-sm text-gray-700 flex flex-wrap gap-x-6 gap-y-1">
        <div>Partner: <strong class="text-gray-900"><%= @order.company.name %></strong></div>
        <div>Kreirano: <strong class="text-gray-900"><%= l(@order.created_at, format: :short) %></strong></div>

        <% if @order.due_date.present? %>
          <div>
            Rok plaćanja:
            <strong class="<%= @order.overdue? ? 'text-red-700' : 'text-gray-900' %>">
              <%= l(@order.due_date, format: :long) %>
            </strong>
          </div>
        <% end %>

        <div>
          Plaćanje:
          <% if @order.paid? %>
            <strong class="text-green-700">Plaćeno</strong>
            <span class="text-gray-500">(<%= l(@order.paid_at, format: :short) %>)</span>
          <% else %>
            <strong class="text-gray-900">Nije plaćeno</strong>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= button_to "Primijeni rabat",
                    apply_discount_admin_order_path(@order),
                    method: :post,
                    form_class: "inline",
                    class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg shadow hover:bg-blue-700 transition focus:outline-none focus:ring-2 focus:ring-blue-400",
                    title: "Ponovno izračunaj iznose prema trenutnim uvjetima partnera (rabat, rok plaćanja)" %>

      <%= button_to "Generiraj ponudu (PDF)",
                    generate_offer_admin_order_path(@order),
                    method: :post,
                    class: btn_primary %>

      <%= button_to "Pošalji ponudu e-poštom",
                    send_offer_admin_order_path(@order),
                    method: :post,
                    class: btn_primary %>

      <% if @order.offer&.pdf&.attached? %>
        <%= link_to "Preuzmi ponudu",
                    rails_blob_path(@order.offer.pdf, disposition: "attachment"),
                    class: btn_gray %>
      <% end %>
    </div>
  </div>

  <div class="mb-6 space-y-1 text-sm text-gray-700">
    <div>OIB: <strong class="text-gray-900"><%= @order.company.oib.presence || "-" %></strong></div>
    <div>Adresa partnera: <strong class="text-gray-900"><%= @order.company.full_address.presence || "-" %></strong></div>
    <div>Adresa dostave: <strong class="text-gray-900"><%= @order.delivery_address.presence || @order.company.full_address.presence || "-" %></strong></div>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
    <h2 class="font-bold text-gray-900 mb-3">Akcije</h2>

    <div class="flex flex-wrap gap-2">
      <% if @order.submitted? %>
        <%= button_to "Odobri",
                      change_status_admin_order_path(@order, to_status: :approved),
                      method: :post,
                      class: btn_green %>

        <%= button_to "Odbij",
                      change_status_admin_order_path(@order, to_status: :rejected),
                      method: :post,
                      class: btn_red %>
      <% end %>

      <% if @order.approved? %>
        <%= button_to "Stavi u pripremu",
                      change_status_admin_order_path(@order, to_status: :preparing),
                      method: :post,
                      class: btn_primary %>
      <% end %>

      <% if @order.preparing? %>
        <%= button_to "Označi kao poslano",
                      change_status_admin_order_path(@order, to_status: :shipped),
                      method: :post,
                      class: btn_primary %>
      <% end %>

      <% if @order.shipped? %>
        <%= button_to "Označi kao dostavljeno",
                      change_status_admin_order_path(@order, to_status: :delivered),
                      method: :post,
                      class: btn_primary %>
      <% end %>

      <% if @order.delivered? && !@order.paid? %>
        <%= button_to "Označi kao plaćeno",
                      mark_paid_admin_order_path(@order),
                      method: :post,
                      class: btn_green %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

    <div class="lg:col-span-2 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-4 py-3 border-b bg-gray-50">
        <h2 class="font-bold text-gray-900">Stavke narudžbe</h2>
      </div>

      <table class="w-full text-sm">
        <thead class="text-gray-600 uppercase text-xs tracking-wider bg-white">
        <tr class="border-b">
          <th class="text-left px-4 py-3">Proizvod</th>
          <th class="text-left px-4 py-3">Količina</th>
          <th class="text-left px-4 py-3">
            VPC
            <span class="block normal-case text-[10px] font-normal text-gray-400">bez PDV-a</span>
          </th>
          <th class="text-left px-4 py-3">PDV</th>
          <th class="text-left px-4 py-3">
            MPC
            <span class="block normal-case text-[10px] font-normal text-gray-400">s PDV-om</span>
          </th>
          <th class="text-left px-4 py-3">
            Iznos
            <span class="block normal-case text-[10px] font-normal text-gray-400">s PDV-om</span>
          </th>
        </tr>
        </thead>

        <tbody class="divide-y divide-gray-200">
        <% @order.order_items.includes(:product).each do |item| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-4 py-3 text-gray-900 font-medium"><%= item.product.name %></td>
            <td class="px-4 py-3 text-gray-800"><%= item.quantity %></td>
            <td class="px-4 py-3 text-gray-800">
              <%= number_to_currency(item.unit_price_cents / 100.0, unit: "€") %>
            </td>
            <td class="px-4 py-3 text-gray-800">
              <%= number_to_currency(item.unit_vat_cents / 100.0, unit: "€") %>
            </td>
            <td class="px-4 py-3 text-gray-800">
              <%= number_to_currency(item.unit_mpc_cents / 100.0, unit: "€") %>
            </td>
            <td class="px-4 py-3 text-gray-900 font-semibold">
              <%= number_to_currency(item.line_mpc_cents / 100.0, unit: "€") %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>

      <p class="px-4 py-3 text-xs text-gray-500 border-t bg-gray-50">
        Napomena: rabat ne utječe na cijene po stavci (VPC/MPC/Iznos) — primjenjuje se zbirno,
        na razini cijele narudžbe (vidi sažetak desno).
      </p>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h2 class="font-bold text-gray-900 mb-3">Sažetak</h2>

      <div class="space-y-2 text-sm">
        <div class="flex justify-between text-gray-700">
          <span>
            Ukupno bez PDV-a
            <span class="block text-[11px] text-gray-400">osnovni zbroj stavki, bez rabata</span>
          </span>
          <span class="font-semibold text-gray-900">
            <%= number_to_currency(@order.subtotal_cents / 100.0, unit: "€") %>
          </span>
        </div>

        <% if @order.discount_cents.to_i.positive? %>
          <div class="flex justify-between text-gray-700">
            <span>Rabat</span>
            <span class="font-semibold text-green-700">
              -<%= number_to_currency(@order.discount_cents / 100.0, unit: "€") %>
            </span>
          </div>

          <div class="flex justify-between text-gray-700">
            <span>
              Osnovica
              <span class="block text-[11px] text-gray-400">bez PDV-a, nakon rabata</span>
            </span>
            <span class="font-semibold text-gray-900">
              <%= number_to_currency((@order.subtotal_cents.to_i - @order.discount_cents.to_i) / 100.0, unit: "€") %>
            </span>
          </div>
        <% else %>
          <div class="text-xs text-gray-400 italic">
            Partner nema dogovoren rabat (0%).
          </div>
        <% end %>

        <div class="flex justify-between text-gray-700">
          <span>PDV (25%)</span>
          <span class="font-semibold text-gray-900">
            <%= number_to_currency(@order.vat_cents / 100.0, unit: "€") %>
          </span>
        </div>

        <div class="border-t pt-3 mt-3 flex justify-between font-bold text-gray-900">
          <span>
            Ukupno
            <span class="block text-[11px] font-normal text-gray-400">s PDV-om</span>
          </span>
          <span><%= number_to_currency(@order.total_cents / 100.0, unit: "€") %></span>
        </div>

        <div class="mt-3 text-sm">
          <% if @order.paid? %>
            <p class="text-green-700 font-semibold">
              ✔ Plaćeno (<%= l(@order.paid_at, format: :short) %>)
            </p>
          <% elsif @order.due_date.present? %>
            <p class="<%= @order.overdue? ? 'text-red-700 font-bold' : 'text-gray-700' %>">
              Rok plaćanja: <%= l(@order.due_date, format: :long) %>
              <% if @order.overdue? %> — KAŠNJENJE <% end %>
            </p>
          <% else %>
            <p class="text-gray-600">Rok plaćanja nije postavljen.</p>
          <% end %>
        </div>
      </div>
    </div>

  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-3">Povijest statusa</h2>

    <% histories = @order.order_status_histories.order(created_at: :asc) %>

    <% if histories.any? %>
      <ul class="space-y-2 text-sm">
        <% histories.each do |h| %>
          <% from_label =
               case Order.statuses.key(h.from_status)
               when "draft" then "Skica"
               when "submitted" then "Poslana"
               when "approved" then "Odobrena"
               when "preparing" then "U pripremi"
               when "shipped" then "Poslana kupcu"
               when "delivered" then "Dostavljena"
               when "rejected" then "Odbijena"
               when "cancelled" then "Otkazana"
               else Order.statuses.key(h.from_status)
               end
          %>

          <% to_label =
               case Order.statuses.key(h.to_status)
               when "draft" then "Skica"
               when "submitted" then "Poslana"
               when "approved" then "Odobrena"
               when "preparing" then "U pripremi"
               when "shipped" then "Poslana kupcu"
               when "delivered" then "Dostavljena"
               when "rejected" then "Odbijena"
               when "cancelled" then "Otkazana"
               else Order.statuses.key(h.to_status)
               end
          %>

          <li class="flex flex-wrap gap-x-2 gap-y-1 text-gray-700">
            <span class="text-gray-500"><%= l(h.created_at, format: :short) %></span>
            <span>—</span>
            <span class="font-semibold text-gray-900"><%= from_label %></span>
            <span>→</span>
            <span class="font-semibold text-gray-900"><%= to_label %></span>
            <span class="text-gray-500">(<%= h.changed_by.email %>)</span>
            <% if h.note.present? %>
              <span class="text-gray-600">— <%= h.note %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-600">Još nema promjena statusa.</p>
    <% end %>
  </div>

</div>
